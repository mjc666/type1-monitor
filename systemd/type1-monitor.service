[Unit]
Description=Type1 Monitor FastAPI Backend
After=network.target mysql.service

[Service]
User=type1
WorkingDirectory=/opt/type1-monitor/backend
ExecStart=/opt/type1-monitor/backend/venv/bin/python3 -m uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
EnvironmentFile=/opt/type1-monitor/backend/.env

[Install]
WantedBy=multi-user.target
